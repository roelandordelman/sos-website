---
import { base } from '../lib/base';

const navItems = [
  { label: 'Over',             href: `${base}over` },
  { label: 'Speech Tech Days', href: `${base}edities` },
  { label: 'Nieuws',           href: `${base}nieuws` },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href={base} class="site-logo">
        <img src={`${base}logo.png`} alt="Open Spraaktechnologie" />
        <span class="logo-text">Open Spraaktechnologie</span>
      </a>
      <nav class="site-nav" aria-label="Hoofdmenu">
        <ul>
          {navItems.map(item => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>
