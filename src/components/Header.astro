---
import { base } from '../lib/base';

const navItems = [
  { label: 'Over',             href: `${base}over` },
  { label: 'Speech Tech Days', href: `${base}edities` },
  { label: 'Projecten',        href: `${base}projecten` },
  { label: 'Benchmarking',     href: 'https://opensource-spraakherkenning-nl.github.io/ASR_NL_results/', external: true },
  { label: 'Agenda',           href: `${base}agenda` },
  { label: 'Nieuws',           href: `${base}nieuws` },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href={base} class="site-logo">
        <img src={`${base}logo.png`} alt="Open Spraaktechnologie" />
        <span class="logo-text">Open Spraaktechnologie</span>
      </a>
      <nav class="site-nav" aria-label="Hoofdmenu">
        <ul>
          {navItems.map(item => (
            <li>
              <a
                href={item.href}
                aria-current={!item.external && currentPath.startsWith(item.href) ? 'page' : undefined}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>
