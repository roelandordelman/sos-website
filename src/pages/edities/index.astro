---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const edities = (await getCollection('edities'))
  .sort((a, b) => b.data.datum.getTime() - a.data.datum.getTime());
---

<BaseLayout title="Speech Tech Days" description="Overzicht van alle edities van de Dutch Speech Tech Day.">
  <div class="container">

    <div class="page-header">
      <h1>Dutch Speech Tech Day</h1>
      <p>
        De jaarlijkse bijeenkomst voor iedereen die betrokken is bij Nederlandse spraaktechnologie —
        onderzoekers, ontwikkelaars, studenten en gebruikers.
      </p>
    </div>

    <ul class="post-list">
      {edities.map(e => (
        <li>
          <p class="post-meta">
            {e.data.datum.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })}
            {e.data.locatie && <> &nbsp;·&nbsp; {e.data.locatie}</>}
          </p>
          <a href={`${base}edities/${e.slug}`} class="post-title">{e.data.title}</a>
          {e.data.beschrijving && <p class="post-description">{e.data.beschrijving}</p>}
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
