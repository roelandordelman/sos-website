---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Over"
  description="Over Stichting Open Spraaktechnologie: missie, bestuur en ANBI-gegevens."
>
  <div class="container">

    <div class="page-header">
      <h1>Over de stichting</h1>
      <p>Stichting Open Spraaktechnologie werd opgericht op 10 mei 2019.</p>
    </div>

    <section class="section" id="missie">
      <h2>Missie &amp; visie</h2>
      <p>
        Stichting Open Spraaktechnologie faciliteert kennisuitwisseling en samenwerking
        rondom de ontwikkeling van hoogwaardige, open Nederlandse spraaktechnologie.
        Wij positioneren ons als katalysator voor een levendig, samenwerkend ecosysteem
        waarin informatie vrij kan stromen tussen onderzoeksinstellingen, industrie,
        overheidsorganisaties en het publiek.
      </p>
    </section>

    <section class="section" id="bestuur">
      <h2>Bestuur</h2>
      <p>
        Het bestuur van de stichting bestaat uit vertegenwoordigers vanuit onderzoek,
        industrie en maatschappelijke organisaties.
      </p>
      <!-- Voeg bestuursleden toe als lijst, bijv.: -->
      <!--
      <ul>
        <li><strong>Voorzitter</strong> — Naam</li>
        <li><strong>Secretaris</strong> — Naam</li>
        <li><strong>Penningmeester</strong> — Naam</li>
      </ul>
      -->
      <p><em>Bestuursinformatie volgt binnenkort.</em></p>
    </section>

    <section class="section" id="anbi">
      <h2>ANBI-gegevens</h2>
      <table style="border-collapse: collapse; width: 100%; max-width: 480px;">
        <tbody>
          <tr>
            <td style="padding: 0.4rem 1rem 0.4rem 0; color: var(--color-text-muted); white-space: nowrap;">Naam</td>
            <td>Stichting Open Spraaktechnologie</td>
          </tr>
          <tr>
            <td style="padding: 0.4rem 1rem 0.4rem 0; color: var(--color-text-muted);">KvK</td>
            <td>74801260</td>
          </tr>
          <tr>
            <td style="padding: 0.4rem 1rem 0.4rem 0; color: var(--color-text-muted);">Opgericht</td>
            <td>10 mei 2019</td>
          </tr>
          <tr>
            <td style="padding: 0.4rem 1rem 0.4rem 0; color: var(--color-text-muted);">RSIN</td>
            <td><em>Volgt</em></td>
          </tr>
          <tr>
            <td style="padding: 0.4rem 1rem 0.4rem 0; color: var(--color-text-muted);">Adres</td>
            <td><em>Volgt</em></td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="section" id="colofon">
      <h2>Colofon</h2>
      <p>
        Deze website is gebouwd met <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        en wordt gehost op <a href="https://codeberg.page" target="_blank" rel="noopener">Codeberg Pages</a>.
        De broncode is beschikbaar op
        <a href="https://codeberg.org/opensource-spraakherkenning-nl/sos-website" target="_blank" rel="noopener">Codeberg</a>.
      </p>
    </section>

  </div>
</BaseLayout>
