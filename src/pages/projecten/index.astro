---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { onderwerpen } from '../../content/config';
import { base } from '../../lib/base';

const projecten = (await getCollection('projecten'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'nl'));

const actief   = projecten.filter(p => p.data.status === 'actief');
const afgerond = projecten.filter(p => p.data.status === 'afgerond');
---

<BaseLayout
  title="Projecten"
  description="Overzicht van lopende en afgeronde spraaktechnologieprojecten in Nederland."
>
  <div class="container">

    <div class="page-header">
      <h1>Projecten</h1>
      <p>
        Lopende en afgeronde spraaktechnologieprojecten in Nederland.
        Wil je jouw project toevoegen?
        <a href="https://github.com/roelandordelman/sos-website/tree/main/src/content/projecten" target="_blank" rel="noopener">
          Gebruik het template op GitHub.
        </a>
      </p>
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="alle">Alle onderwerpen</button>
      {onderwerpen.map(o => (
        <button class="filter-btn" data-filter={o}>{o}</button>
      ))}
    </div>

    <section class="section">
      {actief.length === 0 ? (
        <p style="color: var(--color-text-muted);">Nog geen projecten toegevoegd.</p>
      ) : (
        <div class="projecten-grid" id="projecten-grid">
          {actief.map(project => (
            <a
              href={`${base}projecten/${project.slug}`}
              class="project-card"
              data-onderwerpen={project.data.onderwerp.join('|')}
            >
              {project.data.logo ? (
                <div class="card-logo">
                  <img src={`${base}${project.data.logo}`} alt={`${project.data.title} logo`} />
                </div>
              ) : (
                <div class="card-logo card-logo-placeholder">
                  <span>🎤</span>
                </div>
              )}
              <div class="card-body">
                <h2 class="card-title">{project.data.title}</h2>
                {project.data.instelling && (
                  <p class="card-instelling">{project.data.instelling}</p>
                )}
                <p class="card-beschrijving">{project.data.beschrijving}</p>
                <div class="card-tags">
                  {project.data.onderwerp.map(o => (
                    <span class="tag">{o}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
      <p class="geen-resultaten" style="display:none; color: var(--color-text-muted);">
        Geen projecten gevonden voor dit onderwerp.
      </p>
    </section>

    {afgerond.length > 0 && (
      <section class="section" id="afgerond">
        <h2>Afgeronde projecten</h2>
        <div class="projecten-grid">
          {afgerond.map(project => (
            <a
              href={`${base}projecten/${project.slug}`}
              class="project-card project-card--afgerond"
              data-onderwerpen={project.data.onderwerp.join('|')}
            >
              <div class="card-body">
                <h2 class="card-title">{project.data.title}</h2>
                {project.data.instelling && (
                  <p class="card-instelling">{project.data.instelling}</p>
                )}
                <p class="card-beschrijving">{project.data.beschrijving}</p>
                <div class="card-tags">
                  {project.data.onderwerp.map(o => (
                    <span class="tag">{o}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.project-card');
  const geenResultaten = document.querySelector<HTMLElement>('.geen-resultaten');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'alle';
      let zichtbaar = 0;

      cards.forEach(card => {
        const tags = card.dataset.onderwerpen ?? '';
        const tonen = filter === 'alle' || tags.includes(filter);
        card.style.display = tonen ? '' : 'none';
        if (tonen) zichtbaar++;
      });

      if (geenResultaten) {
        geenResultaten.style.display = zichtbaar === 0 ? '' : 'none';
      }
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .projecten-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: var(--color-bg-alt);
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .project-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    border-color: var(--color-accent);
  }

  .project-card--afgerond {
    opacity: 0.75;
  }

  .card-logo {
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    padding: 1rem;
  }

  .card-logo img {
    max-height: 72px;
    max-width: 100%;
    object-fit: contain;
  }

  .card-logo-placeholder {
    font-size: 2.5rem;
    background: var(--color-bg-alt);
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
  }

  .card-instelling {
    font-size: 0.8rem;
    color: var(--color-accent);
    margin: 0;
    font-weight: 500;
  }

  .card-beschrijving {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0.5rem;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  @media (max-width: 640px) {
    .projecten-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
