---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { base } from '../../lib/base';

export async function getStaticPaths() {
  const items = await getCollection('agenda');
  return items
    .filter(item => item.data.type !== 'extern')
    .map(item => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const typeLabel: Record<string, string> = {
  'speech-tech-day': 'Speech Tech Day',
  'workshop':        'Workshop',
  'school':          'Summer/Winter School',
};

const statusLabel: Record<string, string> = {
  'bevestigd': 'Bevestigd',
  'concept':   'Concept',
  'gepland':   'Gepland',
};
---

<BaseLayout title={item.data.title} description={item.data.beschrijving}>
  <div class="container">
    <nav class="breadcrumb">
      <a href={`${base}agenda`}>← Agenda</a>
    </nav>

    <div class="event-header">
      <span class="event-type">{typeLabel[item.data.type]}</span>
      <h1>{item.data.title}</h1>

      <dl class="event-meta">
        <dt>Datum</dt>
        <dd>
          {item.data.datum.toLocaleDateString('nl-NL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
          {item.data.datum_eind && (
            <> – {item.data.datum_eind.toLocaleDateString('nl-NL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</>
          )}
        </dd>
        {item.data.locatie && (
          <>
            <dt>Locatie</dt>
            <dd>{item.data.locatie}</dd>
          </>
        )}
        <dt>Status</dt>
        <dd>{statusLabel[item.data.status]}</dd>
      </dl>
    </div>

    <div class="event-body prose">
      <Content />
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .event-type {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  h1 { margin-top: 0.25rem; }

  .event-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.4rem 1.5rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }

  .event-meta dt {
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .event-meta dd { margin: 0; }

  .event-body {
    max-width: 720px;
    margin-top: 2rem;
  }
</style>
