---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { base } from '../lib/base';

const nieuws = await getCollection('nieuws');
const recentNieuws = nieuws
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const edities = await getCollection('edities');
const komende = edities
  .filter(e => e.data.datum >= new Date())
  .sort((a, b) => a.data.datum.getTime() - b.data.datum.getTime())
  .slice(0, 1);
---

<BaseLayout title="Home">

  <div class="hero-banner">
    <img src={`${base}soundwave.png`} alt="Spraakgolf visualisatie" class="hero-banner-bg" />
    <img src={`${base}logo-large.png`} alt="Open Spraaktechnologie" class="hero-banner-logo" />
  </div>

  <div class="container">

    <section class="hero">
      <h1>Open Spraaktechnologie</h1>
      <p class="tagline">
        Katalysator voor innovatie rond Nederlandse spraaktechnologie — waar kennis vrij stroomt
        tussen onderzoek, industrie en samenleving.
      </p>
      <div class="hero-actions">
        <a href={`${base}edities`} class="btn">Speech Tech Days</a>
        <a href={`${base}over`} class="btn btn-outline">Over de stichting</a>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Wat we doen</h2>
      <div class="activiteiten-lijst">
        <div class="activiteit">
          <img src={`${base}edities/speechtechdag-2026/web/DSCF0973.JPG`} alt="Dutch Speech Tech Day" class="activiteit-foto" />
          <div>
            <strong><a href={`${base}edities`}>Dutch Speech Tech Day</a></strong>
            <p>Jaarlijkse ontmoetingsplaats voor onderzoekers, ontwikkelaars en gebruikers van spraaktechnologie.</p>
          </div>
        </div>
        <div class="activiteit">
          <img src={`${base}edities/speechtechdag-2026/web/DSCF1072.JPG`} alt="Kennisuitwisseling" class="activiteit-foto" />
          <div>
            <strong>Kennisuitwisseling</strong>
            <p>We verbinden onderzoeksinstellingen, industrie en overheid rondom Nederlandstalige spraaktechnologie.</p>
          </div>
        </div>
        <div class="activiteit">
          <img src={`${base}Word-error-rates.png`} alt="Benchmarking spraakherkenning" class="activiteit-foto" />
          <div>
            <strong><a href="https://opensource-spraakherkenning-nl.github.io/ASR_NL_results/" target="_blank" rel="noopener">Benchmarking</a></strong>
            <p>We stimuleren objectieve evaluatie van de kwaliteit van Nederlandstalige spraakherkenning.</p>
          </div>
        </div>
        <div class="activiteit">
          <img src={`${base}justice-914231_960_720.png`} alt="Verantwoorde toepassing" class="activiteit-foto" />
          <div>
            <strong>Verantwoorde toepassing</strong>
            <p>We adresseren juridische, ethische en maatschappelijke vraagstukken rond spraaktechnologie.</p>
          </div>
        </div>
      </div>
      <p style="margin-top: 1.75rem;">
        <a href={`${base}over`}>Lees meer over onze missie en activiteiten →</a>
      </p>
    </section>

    {komende.length > 0 && (
      <section class="section">
        <h2 class="section-title">Aankomende editie</h2>
        {komende.map(e => (
          <>
            <p>
              <strong><a href={`${base}edities/${e.slug}`}>{e.data.title}</a></strong>
              &nbsp;·&nbsp;
              {e.data.datum.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })}
              {e.data.locatie && <> &nbsp;·&nbsp; {e.data.locatie}</>}
            </p>
            {e.data.beschrijving && <p style="color: var(--color-text-muted); margin-top: 0.5rem;">{e.data.beschrijving}</p>}
          </>
        ))}
      </section>
    )}

    {recentNieuws.length > 0 && (
      <section class="section">
        <h2 class="section-title">Laatste nieuws</h2>
        <ul class="post-list">
          {recentNieuws.map(post => (
            <li class="post-item">
              {post.data.image && (
                <a href={`${base}nieuws/${post.slug}`} class="post-thumb-link">
                  <img
                    src={`${base}${post.data.image}`}
                    alt={post.data.title}
                    class="post-thumb"
                  />
                </a>
              )}
              <div class="post-item-body">
                <p class="post-meta">
                  {post.data.date.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <a href={`${base}nieuws/${post.slug}`} class="post-title">{post.data.title}</a>
                {post.data.description && (
                  <p class="post-description">{post.data.description}</p>
                )}
              </div>
            </li>
          ))}
        </ul>
        <p style="margin-top: 1.25rem;">
          <a href={`${base}nieuws`}>Alle berichten →</a>
        </p>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .activiteiten-lijst {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .activiteit {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg-alt);
  }

  .activiteit-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .activiteit-foto {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .activiteit strong {
    display: block;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .activiteit p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 640px) {
    .activiteiten-lijst {
      grid-template-columns: 1fr;
    }
  }

  .post-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .post-thumb-link {
    flex-shrink: 0;
  }

  .post-thumb {
    width: 100px;
    height: 70px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .post-item-body {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 480px) {
    .post-thumb {
      width: 80px;
      height: 56px;
    }
  }
</style>
